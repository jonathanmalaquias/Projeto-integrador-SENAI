import tkinter as tk
from tkinter import messagebox, ttk, filedialog
from datetime import datetime
import json
import os
import csv

class Maquina:
    def __init__(self, nome, ultima_manutencao, agendamento=None, insumos_usados=None, procedimentos=None):
        self.nome = nome
        self.ultima_manutencao = ultima_manutencao
        self.agendamento = agendamento
        self.insumos_usados = insumos_usados if insumos_usados else []
        self.procedimentos = procedimentos if procedimentos else [] # Novo campo

    def get_status_agendamento(self):
        if not self.agendamento:
            return "Sem agendamento", "black"
        try:
            data_alvo = datetime.strptime(self.agendamento, "%Y-%m-%d")
            hoje = datetime.now().replace(hour=0, minute=0, second=0, microsecond=0)
            diferenca = (data_alvo - hoje).days
            
            if diferenca < 0: return f"VENCIDA ({abs(diferenca)} dias)", "red"
            elif diferenca == 0: return "HOJE!", "orange"
            elif diferenca <= 7: return f"ALERTA: {diferenca} dias", "#b8860b"
            else: return f"Ok ({diferenca} d)", "green"
        except:
            return "Erro data", "black"

class AppManutencao:
    def __init__(self, root):
        self.root = root
        self.root.title("SIGMA - SENAI Gestão de Manutenção")
        self.root.geometry("1000x650")
        
        pasta_usuario = os.path.join(os.path.expanduser("~"), "Documents")
        self.arquivo_dados = os.path.join(pasta_usuario, "dados_manutencao_senai.json")
        
        self.maquinas = self.carregar_dados()
        self.setup_ui()
        self.atualizar_lista()

    def aplicar_mascara(self, event, entry):
        if event.keysym == "BackSpace": return
        texto = entry.get().replace("-", "")
        if not texto.isdigit() and texto != "":
            entry.delete(len(entry.get())-1, tk.END)
            return
        novo_texto = ""
        if len(texto) <= 4: novo_texto = texto
        elif len(texto) <= 6: novo_texto = texto[:4] + "-" + texto[4:]
        else: novo_texto = texto[:4] + "-" + texto[4:6] + "-" + texto[6:8]

        if entry.get() != novo_texto:
            entry.delete(0, tk.END)
            entry.insert(0, novo_texto)

    def setup_ui(self):
        header = tk.Frame(self.root, bg="#004a8d", pady=10)
        header.pack(fill="x")
        tk.Label(header, text="SIGMA - Sistema de Gestão de Manutenção", fg="white", bg="#004a8d", font=("Arial", 14, "bold")).pack()

        frame_cad = tk.LabelFrame(self.root, text=" Cadastro de Nova Máquina ", padx=10, pady=10)
        frame_cad.pack(fill="x", padx=20, pady=10)

        tk.Label(frame_cad, text="Máquina:").grid(row=0, column=0)
        self.ent_nome = tk.Entry(frame_cad, width=25)
        self.ent_nome.grid(row=0, column=1, padx=5)

        tk.Label(frame_cad, text="Agenda (AAAA-MM-DD):").grid(row=0, column=2)
        self.ent_agenda = tk.Entry(frame_cad, width=15)
        self.ent_agenda.grid(row=0, column=3, padx=5)
        self.ent_agenda.bind("<KeyRelease>", lambda e: self.aplicar_mascara(e, self.ent_agenda))
        
        tk.Button(frame_cad, text="➕ ADICIONAR", command=self.adicionar_maquina, bg="#28a745", fg="white", font=("Arial", 10, "bold")).grid(row=0, column=4, padx=10)

        # TABELA COM ORDENAÇÃO
        columns = ("Nome", "Ultima", "Proxima", "Status")
        self.tree = ttk.Treeview(self.root, columns=columns, show="headings")
        
        for col in columns:
            # Comando para ordenar ao clicar no cabeçalho
            self.tree.heading(col, text=col, command=lambda _col=col: self.ordenar_coluna(_col, False))
            self.tree.column(col, anchor="center")

        self.tree.pack(fill="both", expand=True, padx=20, pady=5)
        self.tree.tag_configure("red", foreground="red")
        self.tree.tag_configure("orange", foreground="#ff8c00")

        btn_frame = tk.Frame(self.root)
        btn_frame.pack(pady=15)

        btns = [
            ("⚙️ REGISTRAR MANUTENÇÃO", self.janela_manutencao, "#007bff"),
            ("📋 HISTÓRICO", self.ver_historico, "#6c757d"),
            ("🗑️ REMOVER", self.remover_maquina, "#dc3545"),
            ("📊 EXPORTAR (CSV)", self.exportar_csv, "#1d6f42")
        ]
        for text, cmd, color in btns:
            tk.Button(btn_frame, text=text, command=cmd, bg=color, fg="white", width=22, font=("Arial", 9, "bold")).pack(side="left", padx=5)

    def ordenar_coluna(self, col, reverse):
        # Pega os dados da coluna
        l = [(self.tree.set(k, col), k) for k in self.tree.get_children('')]
        
        # Se for coluna de data ou status, a lógica de sorte muda um pouco
        # mas para simplificar, o Python ordena strings A-Z bem
        l.sort(reverse=reverse)

        # Rearranja os itens na tabela
        for index, (val, k) in enumerate(l):
            self.tree.move(k, '', index)

        # Inverte para o próximo clique
        self.tree.heading(col, command=lambda: self.ordenar_coluna(col, not reverse))

    def salvar_dados(self):
        dados = [m.__dict__ for m in self.maquinas]
        with open(self.arquivo_dados, 'w', encoding='utf-8') as f:
            json.dump(dados, f, indent=4, ensure_ascii=False)

    def carregar_dados(self):
        if os.path.exists(self.arquivo_dados):
            try:
                with open(self.arquivo_dados, 'r', encoding='utf-8') as f:
                    return [Maquina(**m) for m in json.load(f)]
            except: return []
        return []

    def adicionar_maquina(self):
        n, a = self.ent_nome.get(), self.ent_agenda.get()
        if n:
            self.maquinas.append(Maquina(n, "---", a))
            self.salvar_dados(); self.atualizar_lista()
            self.ent_nome.delete(0, tk.END); self.ent_agenda.delete(0, tk.END)
    def remover_maquina(self):
            # 1. Pega o item selecionado na tabela
            sel = self.tree.selection()
            if not sel:
                messagebox.showwarning("Atenção", "Selecione uma máquina para remover!")
                return
            
            # 2. Pega o nome da máquina para confirmar
            nome_maquina = self.tree.item(sel)['values'][0]
            
            # 3. Janela de confirmação (Segurança é tudo!)
            if messagebox.askyesno("Confirmar Exclusão", f"Tem certeza que deseja remover a máquina '{nome_maquina}'?"):
                # Filtra a lista mantendo apenas quem NÃO tem o nome selecionado
                self.maquinas = [m for m in self.maquinas if m.nome != nome_maquina]
                
                # 4. Salva a nova lista no JSON e atualiza a tela
                self.salvar_dados()
                self.atualizar_lista()
                messagebox.showinfo("Sucesso", f"Máquina '{nome_maquina}' removida com sucesso!")

    def atualizar_lista(self):
        for row in self.tree.get_children(): self.tree.delete(row)
        for m in self.maquinas:
            status, _ = m.get_status_agendamento()
            tag = "red" if "VENCIDA" in status else "orange" if "HOJE" in status else ""
            self.tree.insert("", "end", values=(m.nome, m.ultima_manutencao, m.agendamento or "---", status), tags=(tag,))

    def janela_manutencao(self):
        sel = self.tree.selection()
        if not sel: return
        m_nome = self.tree.item(sel)['values'][0]
        
        win = tk.Toplevel(self.root)
        win.geometry("450x550")
        win.title(f"Registrar Manutenção: {m_nome}")

        tk.Label(win, text="Procedimentos Técnicos realizados:", font=("bold")).pack(pady=5)
        txt_proc = tk.Text(win, height=6); txt_proc.pack(padx=10, fill="x")

        tk.Label(win, text="Insumos Utilizados:", font=("bold")).pack(pady=5)
        txt_ins = tk.Text(win, height=4); txt_ins.pack(padx=10, fill="x")

        tk.Label(win, text="Nova Data de Agenda (AAAA-MM-DD):", font=("bold")).pack(pady=5)
        ent_data = tk.Entry(win); ent_data.pack()
        ent_data.bind("<KeyRelease>", lambda e: self.aplicar_mascara(e, ent_data))
        
        def salvar():
            agora = datetime.now().strftime("%d/%m/%Y %H:%M")
            for m in self.maquinas:
                if m.nome == m_nome:
                    m.ultima_manutencao = agora
                    # Salva ambos no histórico
                    registro = f"[{agora}]\nPROCEDIMENTOS: {txt_proc.get('1.0', 'end-1c')}\nINSUMOS: {txt_ins.get('1.0', 'end-1c')}\n"
                    m.insumos_usados.append(registro)
                    if ent_data.get(): m.agendamento = ent_data.get()
                    break
            self.salvar_dados(); self.atualizar_lista(); win.destroy()
            messagebox.showinfo("Sucesso", "Registro de manutenção salvo!")

        tk.Button(win, text="✅ FINALIZAR E SALVAR", bg="green", fg="white", font=("bold"), command=salvar, pady=10).pack(pady=20)

    def ver_historico(self):
        sel = self.tree.selection()
        if not sel: return
        m_nome = self.tree.item(sel)['values'][0]
        for m in self.maquinas:
            if m.nome == m_nome:
                win = tk.Toplevel(self.root); win.title(f"Histórico Completo - {m.nome}"); win.geometry("500x400")
                t = tk.Text(win, padx=10, pady=10)
                t.pack(fill="both", expand=True)
                conteudo = "\n" + "="*40 + "\n"
                conteudo += "\n".join(m.insumos_usados)
                t.insert("1.0", conteudo)
                t.config(state="disabled")

    def exportar_csv(self):
        # Lógica de exportação mantida e atualizada para incluir procedimentos se necessário
        if not self.maquinas: return
        caminho = filedialog.asksaveasfilename(defaultextension=".csv", filetypes=[("CSV files", "*.csv")])
        if caminho:
            with open(caminho, 'w', newline='', encoding='utf-8-sig') as f:
                writer = csv.writer(f, delimiter=';')
                writer.writerow(['Máquina', 'Histórico Completo'])
                for m in self.maquinas:
                    writer.writerow([m.nome, " | ".join(m.insumos_usados)])
            messagebox.showinfo("Sucesso", "CSV Exportado!")

if __name__ == "__main__":
    root = tk.Tk()
    app = AppManutencao(root)
    root.mainloop()