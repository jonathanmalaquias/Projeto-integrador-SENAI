import tkinter as tk
from tkinter import messagebox, ttk, filedialog
from datetime import datetime
import json
import os
import csv

class Maquina:
    def __init__(self, nome, ultima_manutencao, agendamento=None, insumos_usados=None):
        self.nome = nome
        self.ultima_manutencao = ultima_manutencao
        self.agendamento = agendamento
        self.insumos_usados = insumos_usados if insumos_usados else []

    def get_status_agendamento(self):
        if not self.agendamento:
            return "Sem agendamento", "black"
        try:
            data_alvo = datetime.strptime(self.agendamento, "%Y-%m-%d")
            hoje = datetime.now().replace(hour=0, minute=0, second=0, microsecond=0)
            diferenca = (data_alvo - hoje).days
            
            if diferenca < 0: return f"VENCIDA ({abs(diferenca)} dias)", "red"
            elif diferenca == 0: return "HOJE!", "orange"
            elif diferenca <= 7: return f"ALERTA: {diferenca} dias", "#b8860b"
            else: return f"Ok ({diferenca} d)", "green"
        except:
            return "Erro data", "black"

class AppManutencao:
    def __init__(self, root):
        self.root = root
        self.root.title("SENAI - Gestão de Manutenção")
        self.root.geometry("950x600")
        
        pasta_usuario = os.path.join(os.path.expanduser("~"), "Documents")
        self.arquivo_dados = os.path.join(pasta_usuario, "dados_manutencao_senai.json")
        
        self.maquinas = self.carregar_dados()
        self.setup_ui()
        self.atualizar_lista()

    # --- NOVA LÓGICA DE MÁSCARA DE DATA ---
    def aplicar_mascara(self, event, entry):
        # Se a tecla pressionada for Backspace, não faz nada (deixa apagar)
        if event.keysym == "BackSpace":
            return

        texto = entry.get().replace("-", "") # Remove traços atuais para recalcular
        
        # Apenas números são permitidos (opcional, mas bom ter)
        if not texto.isdigit() and texto != "":
            # Remove o último caractere se não for número
            entry.delete(len(entry.get())-1, tk.END)
            return

        novo_texto = ""
        if len(texto) <= 4:
            novo_texto = texto
        elif len(texto) <= 6:
            novo_texto = texto[:4] + "-" + texto[4:]
        else:
            novo_texto = texto[:4] + "-" + texto[4:6] + "-" + texto[6:8]

        # Atualiza o campo apenas se houve mudança para evitar recursão infinita
        if entry.get() != novo_texto:
            entry.delete(0, tk.END)
            entry.insert(0, novo_texto)

    def setup_ui(self):
        header = tk.Frame(self.root, bg="#004a8d", pady=10)
        header.pack(fill="x")
        tk.Label(header, text="SIGMA - Sistema de Gestão de Manutenção", fg="white", bg="#004a8d", font=("Arial", 14, "bold")).pack()

        frame_cad = tk.LabelFrame(self.root, text=" Cadastro e Agendamento ", padx=10, pady=10)
        frame_cad.pack(fill="x", padx=20, pady=10)

        tk.Label(frame_cad, text="Máquina:").grid(row=0, column=0)
        self.ent_nome = tk.Entry(frame_cad, width=20)
        self.ent_nome.grid(row=0, column=1, padx=5)

        tk.Label(frame_cad, text="Agenda (AAAA-MM-DD):").grid(row=0, column=2)
        self.ent_agenda = tk.Entry(frame_cad, width=15)
        self.ent_agenda.grid(row=0, column=3, padx=5)
        
        # Bind da máscara aqui
        self.ent_agenda.bind("<KeyRelease>", lambda event: self.aplicar_mascara(event, self.ent_agenda))
        
        tk.Button(frame_cad, text="➕ ADICIONAR", command=self.adicionar_maquina, bg="#28a745", fg="white", font=("bold")).grid(row=0, column=4, padx=10)

        # TABELA
        self.tree = ttk.Treeview(self.root, columns=("Nome", "Ultima", "Proxima", "Status"), show="headings")
        self.tree.heading("Nome", text="Máquina"); self.tree.heading("Ultima", text="Última Manut."); self.tree.heading("Proxima", text="Agendada"); self.tree.heading("Status", text="Situação")
        self.tree.pack(fill="both", expand=True, padx=20, pady=5)

        self.tree.tag_configure("red", foreground="red")
        self.tree.tag_configure("orange", foreground="#ff8c00")

        # BOTÕES
        btn_frame = tk.Frame(self.root)
        btn_frame.pack(pady=15)

        btns = [
            ("⚙️ MANUTENÇÃO", self.janela_manutencao, "#007bff"),
            ("📋 HISTÓRICO", self.ver_historico, "#6c757d"),
            ("🗑️ REMOVER", self.remover_maquina, "#dc3545"),
            ("📊 EXPORTAR (CSV)", self.exportar_csv, "#1d6f42")
        ]
        for text, cmd, color in btns:
            tk.Button(btn_frame, text=text, command=cmd, bg=color, fg="white", width=18, font=("bold")).pack(side="left", padx=5)

    def salvar_dados(self):
        try:
            dados = [m.__dict__ for m in self.maquinas]
            with open(self.arquivo_dados, 'w', encoding='utf-8') as f:
                json.dump(dados, f, indent=4, ensure_ascii=False)
        except Exception as e:
            messagebox.showerror("Erro de Permissão", f"Feche o arquivo ou verifique as permissões:\n{e}")

    def carregar_dados(self):
        if os.path.exists(self.arquivo_dados):
            try:
                with open(self.arquivo_dados, 'r', encoding='utf-8') as f:
                    return [Maquina(**m) for m in json.load(f)]
            except: return []
        return []

    def adicionar_maquina(self):
        n, a = self.ent_nome.get(), self.ent_agenda.get()
        if n:
            self.maquinas.append(Maquina(n, "---", a))
            self.salvar_dados(); self.atualizar_lista()
            self.ent_nome.delete(0, tk.END); self.ent_agenda.delete(0, tk.END)

    def remover_maquina(self):
        sel = self.tree.selection()
        if not sel: return
        nome = self.tree.item(sel)['values'][0]
        if messagebox.askyesno("Confirmar", f"Remover {nome}?"):
            self.maquinas = [m for m in self.maquinas if m.nome != nome]
            self.salvar_dados(); self.atualizar_lista()

    def atualizar_lista(self):
        for row in self.tree.get_children(): self.tree.delete(row)
        for m in self.maquinas:
            status, _ = m.get_status_agendamento()
            tag = "red" if "VENCIDA" in status else "orange" if "HOJE" in status or "URGENTE" in status else ""
            self.tree.insert("", "end", values=(m.nome, m.ultima_manutencao, m.agendamento or "---", status), tags=(tag,))

    def exportar_csv(self):
        if not self.maquinas: return
        caminho = filedialog.asksaveasfilename(defaultextension=".csv", filetypes=[("CSV files", "*.csv")])
        if caminho:
            try:
                with open(caminho, 'w', newline='', encoding='utf-8-sig') as f:
                    writer = csv.writer(f, delimiter=';')
                    writer.writerow(['Máquina', 'Data/Hora Manutenção', 'Insumos Utilizados'])
                    for m in self.maquinas:
                        if not m.insumos_usados:
                            writer.writerow([m.nome, 'N/A', 'Sem histórico'])
                        for reg in m.insumos_usados:
                            partes = reg.split("] Insumos: ")
                            data = partes[0].replace("[", "") if len(partes) > 1 else "---"
                            insumo = partes[1] if len(partes) > 1 else reg
                            writer.writerow([m.nome, data, insumo])
                messagebox.showinfo("Sucesso", "Relatório CSV exportado!")
            except Exception as e: messagebox.showerror("Erro", str(e))

    def janela_manutencao(self):
        sel = self.tree.selection()
        if not sel: return
        m_nome = self.tree.item(sel)['values'][0]
        win = tk.Toplevel(self.root); win.geometry("350x400"); win.title("Relatório")
        tk.Label(win, text="Insumos:").pack(); txt = tk.Text(win, height=5); txt.pack()
        tk.Label(win, text="Nova Agenda (AAAA-MM-DD):").pack(); ent = tk.Entry(win); ent.pack()
        
        # Bind da máscara no campo de data da janela pop-up também
        ent.bind("<KeyRelease>", lambda event: self.aplicar_mascara(event, ent))
        
        def salvar():
            agora = datetime.now().strftime("%d/%m/%Y %H:%M")
            for m in self.maquinas:
                if m.nome == m_nome:
                    m.ultima_manutencao = agora
                    m.insumos_usados.append(f"[{agora}] Insumos: {txt.get('1.0', 'end-1c')}")
                    if ent.get(): m.agendamento = ent.get()
                    break
            self.salvar_dados(); self.atualizar_lista(); win.destroy()
        tk.Button(win, text="SALVAR", bg="green", fg="white", command=salvar).pack(pady=10)

    def ver_historico(self):
        sel = self.tree.selection()
        if not sel: return
        m_nome = self.tree.item(sel)['values'][0]
        for m in self.maquinas:
            if m.nome == m_nome:
                win = tk.Toplevel(self.root); win.title(f"Histórico {m.nome}")
                t = tk.Text(win); t.pack(); t.insert("1.0", "\n".join(m.insumos_usados)); t.config(state="disabled")

if __name__ == "__main__":
    root = tk.Tk()
    app = AppManutencao(root)
    root.mainloop()